# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key   # Settings → API → service_role

# ── Stripe (usar sk_live_ en producción, sk_test_ en dev) ─────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...             # Dashboard → Webhooks → signing secret
STRIPE_PRICE_ID=price_...                   # Dashboard → Products → precio mensual

# ── Agora (video calls 1-a-1) ─────────────────────────────────
AGORA_APP_ID=tu-agora-app-id
AGORA_APP_CERTIFICATE=tu-agora-certificate

# ── Web Push (VAPID) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key

# ── mediasoup (live shows) ────────────────────────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=tu-ip-publica       # IP pública del servidor Railway/Fly
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40099                    # Rango reducido (100 puertos)

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://tu-dominio.vercel.app  # URL del frontend en Vercel

# ── Admin ─────────────────────────────────────────────────────
ADMIN_USER_IDS=tu-email@dominio.com         # Email del admin (case-insensitive)

# ── Soporte ───────────────────────────────────────────────────
SUPPORT_EMAIL=soporte@tu-dominio.com
