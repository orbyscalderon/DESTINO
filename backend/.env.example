# ════════════════════════════════════════════════════════════════════════════
# Destino TV — Backend Environment Variables
# Versión: v71 (post-launch hardening)
# Entidad operadora: OC Moon Group LLC
#
# COPY este archivo como `.env` y rellena con valores reales.
# NUNCA commits .env al repo.
# ════════════════════════════════════════════════════════════════════════════

# ── Core servidor ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://destino.app
BACKEND_URL=https://api.destino.app
SLOW_REQUEST_MS=800

# ── Supabase (CRÍTICO) ────────────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
# El código acepta AMBOS nombres (legacy + oficial). Usa cualquiera.
SUPABASE_SERVICE_KEY=tu-service-role-key        # Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key # alias oficial
SUPABASE_ANON_KEY=tu-anon-key                   # usado por exploreController para embeds
SUPABASE_STORAGE_BUCKET=DESTINO

# ── Stripe (CRÍTICO en producción) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                   # sk_test_ en desarrollo
STRIPE_WEBHOOK_SECRET=whsec_...                 # Dashboard → Webhooks → signing secret
STRIPE_PRICE_ID=price_...                       # Producto Premium $9.99/mes
STRIPE_VIP_PRICE_ID=price_...                   # Producto VIP $24.99/mes

# ── CCBill (CRÍTICO para sección adult) ──────────────────────────────────────
CCBILL_FLEXFORMS_DOMAIN=api.ccbill.com
CCBILL_ACCOUNT_NUMBER=tu-account-number         # 9-dígitos de tu sub-account
CCBILL_WEBHOOK_HMAC_SECRET=tu-hmac-secret       # de tu sub-account CCBill

# ── LiveKit ──────────────────────────────────────────────────────────────────
# HOY: LiveKit Cloud (un solo nodo). Crear proyecto en https://cloud.livekit.io
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=APIxxxxx
LIVEKIT_API_SECRET=xxxxxxxxx
# RTMP_INGRESS_URL=                             # opcional, solo si Ingress está activado en LiveKit Cloud

# MIGRACIÓN: LiveKit self-hosted en Vultr (descomentar cuando migres)
# El código autoadapta — videoProvider.js + rtmpController.js
# LIVEKIT_URL_LATAM=wss://livekit-sp.destino.app
# LIVEKIT_KEY_LATAM=key-generada-en-sp
# LIVEKIT_SECRET_LATAM=secret-generado-en-sp
# LIVEKIT_URL_US=wss://livekit-la.destino.app
# LIVEKIT_KEY_US=
# LIVEKIT_SECRET_US=
# LIVEKIT_URL_EUROPA=wss://livekit-mad.destino.app
# LIVEKIT_KEY_EUROPA=
# LIVEKIT_SECRET_EUROPA=
# LIVEKIT_URL_ASIA=wss://livekit-sg.destino.app
# LIVEKIT_KEY_ASIA=
# LIVEKIT_SECRET_ASIA=
# LIVEKIT_URL_OCEANIA=wss://livekit-syd.destino.app
# LIVEKIT_KEY_OCEANIA=
# LIVEKIT_SECRET_OCEANIA=

# ── Storage de media ─────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase                       # supabase | backblaze
SUPABASE_STORAGE_BUCKET=DESTINO

# MIGRACIÓN futura: Backblaze B2 + BunnyCDN (más barato para media pesada)
# STORAGE_PROVIDER=backblaze
# B2_KEY_ID=tu-key-id-de-backblaze
# B2_APP_KEY=tu-application-key
# B2_BUCKET_ID=tu-bucket-id
# B2_BUCKET_NAME=destino-media
# BUNNYCDN_URL=https://destino.b-cdn.net

# ── Moderación de contenido ──────────────────────────────────────────────────
# OpenAI: usado por moderación de texto + AI assistant (icebreakers + persona)
OPENAI_API_KEY=sk-...

# Sightengine: moderación de imagen y video (vault, posts, reels)
# Plan gratis: 2,000 requests/mes en https://sightengine.com
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=

# ── Email transaccional ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Destino TV <noreply@destino.app>
SUPPORT_EMAIL=soporte@destino.app

# ── Inboxes de compliance (Google Workspace) ─────────────────────────────────
# Estos NO son env vars usadas por código — viven en compliance_config table.
# Aquí solo de referencia para que existan en tu workspace:
# - dpo@destino.app
# - legal@destino.app
# - dmca@destino.app
# - records@destino.app (custodian 2257)
# - breach@destino.app

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generar: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key

# ── Firebase FCM (Push Android) ─────────────────────────────────────────────
# Service Account JSON en una línea (escape comillas)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ── Seguridad ────────────────────────────────────────────────────────────────
# Cloudflare Turnstile (anti-bot en signup)
TURNSTILE_SECRET_KEY=

# Encriptación de datos sensibles — generar con: openssl rand -hex 32
PAYOUT_ENCRYPTION_KEY=                          # encripta info bancaria de payouts
TOTP_ENCRYPTION_KEY=                            # encripta secretos 2FA

# Admin extra (además del SUPER_ADMIN_EMAIL hardcoded en backend/middleware/admin.js)
ADMIN_USER_IDS=

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Watermark FFmpeg worker (opcional, post-MVP) ────────────────────────────
# Si activás watermark server-side para adult, instalá: npm i fluent-ffmpeg
# Y añadí ffmpeg al container Railway: nixpacks.toml con nixPkgs = ["ffmpeg"]
WATERMARK_WORKER_ENABLED=false

# ── TLS (NUNCA en producción) ────────────────────────────────────────────────
# NODE_TLS_REJECT_UNAUTHORIZED=0                # solo dev local con certs autofirmados
