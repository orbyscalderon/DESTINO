# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
# El código acepta AMBOS nombres (legacy + oficial). Usa cualquiera.
SUPABASE_SERVICE_KEY=tu-service-role-key        # Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key # alias oficial

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                   # sk_test_ en desarrollo
STRIPE_WEBHOOK_SECRET=whsec_...                 # Dashboard → Webhooks → signing secret
STRIPE_PRICE_ID=price_...                       # Producto Premium $9.99/mes
STRIPE_VIP_PRICE_ID=price_...                   # Producto VIP $24.99/mes

# ── LiveKit ───────────────────────────────────────────────────
# HOY: LiveKit Cloud (un solo nodo)
LIVEKIT_URL=wss://destino-e7a9u6cp.livekit.cloud
LIVEKIT_API_KEY=APIxxxxx
LIVEKIT_API_SECRET=xxxxxxxxx

# MIGRACIÓN: LiveKit self-hosted en Vultr (descomentar cuando migres)
# Cada nodo es un VPS con LiveKit instalado — solo cambia estas vars, cero código
# LIVEKIT_URL_LATAM=wss://livekit-sp.destino.app
# LIVEKIT_KEY_LATAM=key-generada-en-sp
# LIVEKIT_SECRET_LATAM=secret-generado-en-sp
#
# LIVEKIT_URL_US=wss://livekit-la.destino.app
# LIVEKIT_KEY_US=key-generada-en-la
# LIVEKIT_SECRET_US=secret-generado-en-la
#
# LIVEKIT_URL_EUROPA=wss://livekit-mad.destino.app
# LIVEKIT_KEY_EUROPA=key-generada-en-mad
# LIVEKIT_SECRET_EUROPA=secret-generado-en-mad
#
# LIVEKIT_URL_ASIA=wss://livekit-sg.destino.app      # Fase 2
# LIVEKIT_KEY_ASIA=key-generada-en-sg
# LIVEKIT_SECRET_ASIA=secret-generado-en-sg
#
# LIVEKIT_URL_OCEANIA=wss://livekit-syd.destino.app  # Fase 3
# LIVEKIT_KEY_OCEANIA=key-generada-en-syd
# LIVEKIT_SECRET_OCEANIA=secret-generado-en-syd

# ── Storage de archivos ───────────────────────────────────────
# HOY: Supabase Storage (no necesita config extra)
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=DESTINO

# MIGRACIÓN: Backblaze B2 + BunnyCDN (descomentar cuando migres)
# Permite adult content explícitamente — egreso $0.01/GB vs $0.09/GB de Supabase
# STORAGE_PROVIDER=backblaze
# B2_KEY_ID=tu-key-id-de-backblaze
# B2_APP_KEY=tu-application-key
# B2_BUCKET_ID=tu-bucket-id
# B2_BUCKET_NAME=destino-media
# BUNNYCDN_URL=https://destino.b-cdn.net       # Pull Zone apuntando al bucket B2

# ── Web Push (VAPID) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=tu-vapid-public-key
VAPID_PRIVATE_KEY=tu-vapid-private-key

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://destino.app
ADMIN_USER_IDS=orbys85@gmail.com

# ── Encriptación de datos de pago ────────────────────────────
PAYOUT_ENCRYPTION_KEY=clave-hex-de-32-bytes     # openssl rand -hex 32

# ── Soporte ───────────────────────────────────────────────────
SUPPORT_EMAIL=soporte@destino.app

# ── Moderación automática (Sightengine) ──────────────────────
# Plan gratis: 2,000 requests/mes en https://sightengine.com
# Si no se configura, los posts/stories suben sin moderación automática
# (siguen yendo a la cola manual del admin si se marcan como adultos)
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=
