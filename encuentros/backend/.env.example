# ════════════════════════════════════════════════════════════════════
# Encuentros Backend — Environment Variables
# ════════════════════════════════════════════════════════════════════
# Copiar a .env y rellenar. NO commitear .env (ya está en .gitignore).
#
# Para PROD: estos valores van en el dashboard de Railway/Render/Fly
# NO compartas estas keys con NADIE (especialmente service_role).

# Puerto del servidor
PORT=4100

# Modo del entorno: development | production | test
NODE_ENV=development

# ── Supabase project SEPARADO (NO el de Destino TV) ───────────────────
# Crear un project nuevo en supabase.com con dashboard dedicado.
# El service_role key da acceso BYPASS RLS — guardar como secret.
ENCUENTROS_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
ENCUENTROS_SUPABASE_SERVICE_KEY=eyJhbGc...your_service_role_key

# ── Frontend URL para CORS allowlist ──────────────────────────────────
# En prod debe ser el domain del frontend desplegado.
# Múltiples comas-separadas si tenés preview deploys.
FRONTEND_URL=http://localhost:5180,https://encuentros-demo.vercel.app

# ── Payment processor (CUANDO ESTE LISTO) ─────────────────────────────
# Verotel / MobiusPay / SegPay con escort license.
# Stripe y CCBill normales NO aceptan este modelo.
PROCESSOR=verotel
VEROTEL_SHOP_ID=
VEROTEL_SIGNATURE_KEY=
VEROTEL_RETURN_URL=https://encuentrosdo.com/#/checkout/success
VEROTEL_WEBHOOK_SECRET=

# Alternativos
MOBIUSPAY_MERCHANT_ID=
MOBIUSPAY_API_KEY=
MOBIUSPAY_WEBHOOK_SECRET=

# ── Age verification provider ─────────────────────────────────────────
# Onfido / Jumio / Veriff — verificación de documento + selfie
AGE_VERIFY_PROVIDER=onfido
ONFIDO_API_TOKEN=
ONFIDO_WEBHOOK_TOKEN=

# ── Storage para fotos + documentos KYC ───────────────────────────────
# Backblaze B2 / AWS S3 con encriptación at-rest.
# NO usar el mismo bucket que Destino TV.
B2_BUCKET=encuentros-media-prod
B2_KEY_ID=
B2_APP_KEY=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# ── Resend para emails transactionales ────────────────────────────────
# Dominio propio (encuentros.app, NO destino.app)
RESEND_API_KEY=
EMAIL_FROM=encuentros <no-reply@encuentros.app>
SUPPORT_EMAIL=soporte@encuentros.app

# ── Admin del producto (notificaciones de reportes urgentes) ──────────
# Email separado del de Destino TV.
ADMIN_EMAIL=admin@encuentros.app
URGENT_REPORTS_EMAIL=safety@encuentros.app
