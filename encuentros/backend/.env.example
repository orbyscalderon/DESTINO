# ════════════════════════════════════════════════════════════════════
# Encuentros Backend — Environment Variables (v0.2)
# ════════════════════════════════════════════════════════════════════
# Copiar a .env y rellenar. NO commitear .env.
# Para PROD: setear en Railway/Render dashboard.

PORT=4100
NODE_ENV=development

# ── Supabase project SEPARADO (NO el de Destino TV) ───────────────────
ENCUENTROS_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
ENCUENTROS_SUPABASE_SERVICE_KEY=eyJhbGc...

# Storage bucket name (en el mismo Supabase project)
ENCUENTROS_STORAGE_BUCKET=encuentros-photos

# ── CORS allowlist (frontend URLs separadas por coma) ─────────────────
FRONTEND_URL=http://localhost:5180,https://tu-dominio.com

# URL del admin dashboard (para incluir en emails)
ADMIN_URL=https://tu-dominio.com

# ── Payment processor ────────────────────────────────────────────────
# Verotel, MobiusPay, SegPay tienen escort license. CCBill SafetyNet
# acepta algunos pero NO recomendado para esto.
# Stripe NO acepta este modelo bajo ninguna condición.
PRIMARY_PROCESSOR=verotel

# Verotel Flexpay
VEROTEL_MERCHANT_ID=
VEROTEL_SHOP_ID=
VEROTEL_FLEX_SECRET=

# MobiusPay
MOBIUS_MERCHANT_ID=
MOBIUS_WEBHOOK_SECRET=

# SegPay
SEGPAY_WEBHOOK_SECRET=

# ── Age verification ─────────────────────────────────────────────────
# El frontend integra el SDK del provider. El backend recibe el check_id
# y verifica vía webhook.
ONFIDO_API_TOKEN=
ONFIDO_WEBHOOK_TOKEN=

# ── Email (transactional) ────────────────────────────────────────────
# Resend o SendGrid. Si ninguno, modo dev (log to stdout).
MAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
MAIL_FROM=encuentros <no-reply@encuentros.app>

# Recipient para reportes urgentes (underage/trafficking) — escalación 30min
URGENT_REPORTS_EMAIL=safety@encuentros.app
# Recipient para digest diario
DAILY_DIGEST_EMAIL=admin@encuentros.app
