# ════════════════════════════════════════════════════════════════════
# Encuentros Frontend — Environment Variables
# ════════════════════════════════════════════════════════════════════
# Copiar a .env y rellenar. Las vars que empiezan con VITE_ son
# públicas (van al bundle). NO poner secrets acá.

# URL del backend de Encuentros
VITE_API_URL=http://localhost:4100

# URL pública del frontend (para canonicals, og:url)
VITE_PUBLIC_URL=https://tu-dominio.com

# Branding (configurable para multi-tenant futuro)
VITE_BRAND_NAME=encuentros
VITE_BRAND_TAGLINE=Directorio de adultos
VITE_BRAND_PRIMARY_COLOR=#f97316

# Analytics (opcional)
VITE_PLAUSIBLE_DOMAIN=tu-dominio.com
VITE_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js
