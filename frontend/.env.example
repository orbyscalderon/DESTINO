# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key              # Settings → API → anon/public

# ── Backend API ───────────────────────────────────────────────
VITE_API_URL=https://destino-production.up.railway.app

# ── Stripe ────────────────────────────────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_live_...              # pk_test_ en desarrollo

# ── Web Push ──────────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key       # Mismo que backend VAPID_PUBLIC_KEY

# ── AdMob (solo aplica en iOS/Android via Capacitor) ──────────
VITE_ADMOB_APP_ID=ca-app-pub-xxxxx~xxxxx
VITE_ADMOB_BANNER_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_REWARDED_ID=ca-app-pub-xxxxx/xxxxx

# ── Cloudflare Turnstile (protege registro y login de bots) ───
# VITE_TURNSTILE_SITE_KEY=tu-site-key           # Descomentar cuando configures Turnstile

# ── Sentry (monitoreo de errores) ─────────────────────────────
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx         # Descomentar cuando configures Sentry

# ── Soporte ───────────────────────────────────────────────────
VITE_SUPPORT_EMAIL=soporte@destino.app
