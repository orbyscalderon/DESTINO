# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key          # Settings → API → anon/public

# ── Backend API ───────────────────────────────────────────────
VITE_API_URL=https://tu-backend.railway.app  # URL del backend en Railway

# ── Stripe (usar pk_live_ en producción, pk_test_ en dev) ─────
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# ── Agora (video calls) ───────────────────────────────────────
VITE_AGORA_APP_ID=tu-agora-app-id

# ── Web Push ──────────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key    # Mismo que backend VAPID_PUBLIC_KEY

# ── AdMob (solo aplica en iOS/Android via Capacitor) ──────────
VITE_ADMOB_APP_ID=ca-app-pub-xxxxx~xxxxx
VITE_ADMOB_BANNER_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_REWARDED_ID=ca-app-pub-xxxxx/xxxxx

# ── Sentry (opcional pero recomendado) ────────────────────────
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Soporte ───────────────────────────────────────────────────
VITE_SUPPORT_EMAIL=soporte@tu-dominio.com
