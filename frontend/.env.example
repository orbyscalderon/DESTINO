# ════════════════════════════════════════════════════════════════════════════
# Destino TV — Frontend (Vite) Environment Variables
# Versión: v71
#
# COPY como `.env` para desarrollo local. NUNCA commits .env al repo.
# Para producción: configurar en Cloudflare Pages / Vercel dashboard.
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key              # Settings → API → anon/public

# ── Backend API ──────────────────────────────────────────────────────────────
VITE_API_URL=https://api.destino.app

# ── Stripe ───────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLIC_KEY=pk_live_...              # pk_test_ en desarrollo

# ── LiveKit (URL pública del cluster) ───────────────────────────────────────
VITE_LIVEKIT_URL=wss://tu-proyecto.livekit.cloud

# ── Web Push ─────────────────────────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key       # Mismo que backend VAPID_PUBLIC_KEY

# ── AdMob (solo iOS/Android via Capacitor) ──────────────────────────────────
VITE_ADMOB_APP_ID=ca-app-pub-xxxxx~xxxxx
VITE_ADMOB_BANNER_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxx/xxxxx
VITE_ADMOB_REWARDED_ID=ca-app-pub-xxxxx/xxxxx

# ── Cloudflare Turnstile (anti-bot en signup) ───────────────────────────────
VITE_TURNSTILE_SITE_KEY=

# ── Sentry (frontend error monitoring) ──────────────────────────────────────
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── PostHog (analytics) ──────────────────────────────────────────────────────
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Soporte ──────────────────────────────────────────────────────────────────
VITE_SUPPORT_EMAIL=soporte@destino.app

# ── iOS App Store build flag ────────────────────────────────────────────────
# Cuando hacés build para App Store, set a 1 — oculta sección adult para
# pasar Apple Guideline 1.1.4. Para Android/Web/PWA, dejar sin definir.
# Setear ANTES del build: `VITE_IOS_BUILD=1 npm run build`
# VITE_IOS_BUILD=1

# ── Admin emails (frontend gate, backend es source of truth) ────────────────
# Comma-separated. Solo afecta UX: si el user no está en esta lista, no
# muestra el panel admin. Backend isAdmin middleware sigue chequeando.
VITE_ADMIN_EMAILS=admin@tu-dominio.com

# ── Encuentros (sitio partner externo) ──────────────────────────────────────
# Sitio classifieds independiente operado por LLC offshore separada.
# DEFAULT: VACIO — no se muestra el link en Destino TV.
# Activar SOLO cuando el sitio esté operacional (LLC + processor + domain).
# VITE_ENCUENTROS_URL=https://tu-dominio-de-encuentros.com
